{
  "scope": "aux4",
  "name": "repository",
  "version": "1.0.0",
  "description": "Simplified aux4 database",
  "tags": [
    "aux4",
    "database",
    "repository"
  ],
  "system": [
    [
      "test:jq",
      "brew:jq",
      "apt:jq",
      "linux:jq"
    ],
    [
      "test:sqlite3",
      "brew:sqlite",
      "apt:sqlite3"
    ]
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "repository",
          "execute": [
            "profile:repository"
          ],
          "help": {
            "text": "Simplified aux4 database"
          }
        }
      ]
    },
    {
      "name": "repository",
      "commands": [
        {
          "name": "init",
          "private": true,
          "execute": [
            "sqlite3 ${db} \"SELECT name FROM sqlite_master WHERE type = 'table' and name = '${repository}'\" | grep -q ${repository} || cat ${packageDir}/sql/create.sql | sed 's/TABLE_NAME/${repository}/g' | sqlite3 ${db}"
          ],
          "help": {
            "text": "Initialize the aux4 repository",
            "variables": [
              {
                "name": "db",
                "text": "The database to initialize",
                "default": ".local.db"
              },
              {
                "name": "repository",
                "text": "The name of the repository to initialize",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "write",
          "execute": [
            "aux4 repository init --db ${db} --repository ${repository}",
            "set:tmpInput=!mktemp /tmp/aux4_input.XXXXXX",
            "set:tmpInsert=!mktemp /tmp/aux4_insert.XXXXXX",
            "stdin:if(data) && echo '${data}' > ${tmpInput} || cat > ${tmpInput}",
            "set:key=!if(id) && echo '${id}' || (jq -r '.id // empty' ${tmpInput} | grep -q . && jq -r '.id' ${tmpInput}) || uuidgen",
            "set:data=!jq -c 'del(.id)' ${tmpInput} | sed -e 's/\"/\\\\\"/g' -e \"s/'/''/g\"",
            "set:metadata_escaped=!echo value(metadata) | jq -c . | sed -e 's/\"/\\\\\"/g' -e \"s/'/''/g\"",
            "cat ${packageDir}/sql/insert.sql | sed -e 's/TABLE_NAME/${repository}/g' | sed -e 's/KEY/${key}/g' | sed -e 's/JSON_DATA/${data}/g' | sed -e 's/METADATA/${metadata_escaped}/g' > ${tmpInsert}",
            "sqlite3 ${db} < ${tmpInsert}",
            "rm -f ${tmpInsert} ${tmpInput}",
            "log:${key}"
          ],
          "help": {
            "text": "Write to the aux4 repository",
            "variables": [
              {
                "name": "db",
                "text": "The database to write to",
                "default": ".local.db"
              },
              {
                "name": "repository",
                "text": "The name of the repository to write to",
                "arg": true
              },
              {
                "name": "id",
                "text": "The id to write to the repository",
                "default": ""
              },
              {
                "name": "data",
                "text": "The data to write to the repository (JSON string)",
                "default": ""
              },
              {
                "name": "metadata",
                "text": "Optional metadata to store with the record",
                "default": "{}"
              }
            ]
          }
        },
        {
          "name": "read",
          "execute": [
            "aux4 repository init --db ${db} --repository ${repository}",
            "set:tmpFile=!mktemp /tmp/aux4_read.XXXXXX",
            "nout:if(id) && echo \"SELECT id, data, metadata, created_at, updated_at FROM ${repository} WHERE id = value(id)\" || echo \"SELECT id, data, metadata, created_at, updated_at FROM ${repository}\"",
            "set:sql=${response}",
            "sqlite3 -json ${db} \"${sql}\" > ${tmpFile}",
            "if(raw==true) && if [ -s ${tmpFile} ]; then cat ${tmpFile} | jq 'map(. as $$row | ({\"id\": $$row.id} + ($$row.data | fromjson)) + {\"__metadata\": (($$row.metadata | fromjson) + {\"createdAt\": $$row.created_at, \"updatedAt\": $$row.updated_at})})'; else echo '[]'; fi || true",
            "if(raw!=true) && if [ -s ${tmpFile} ]; then cat ${tmpFile} | jq 'map(. as $$row | ({\"id\": $$row.id} + ($$row.data | fromjson)))'; else echo '[]'; fi || true",
            "rm -f ${tmpFile}"
          ],
          "help": {
            "text": "Read from the aux4 repository",
            "variables": [
              {
                "name": "db",
                "text": "The database to read from",
                "default": ".local.db"
              },
              {
                "name": "repository",
                "text": "The name of the repository to read from",
                "arg": true
              },
              {
                "name": "id",
                "text": "The id to read from the repository",
                "default": ""
              },
              {
                "name": "raw",
                "text": "Include metadata in the output",
                "default": "false"
              }
            ]
          }
        },
        {
          "name": "find",
          "execute": [
            "aux4 repository init --db ${db} --repository ${repository}",
            "set:tmpWhere=!mktemp /tmp/aux4_where.XXXXXX",
            "set:tmpResult=!mktemp /tmp/aux4_find.XXXXXX",
            "echo value(expr) > ${tmpWhere}",
            "sed -i '' -E \"s/([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*(=|!=|<>|<=|>=|<|>|like|not like)[[:space:]]*('[^']*'|[^[:space:]]+)/json_extract(data, '$.\\1') \\2 \\3/gi\" ${tmpWhere}",
            "set:where_clause=!cat '${tmpWhere}'",
            "sqlite3 -json ${db} \"SELECT id, data, metadata, created_at, updated_at FROM ${repository} WHERE ${where_clause}\" > ${tmpResult}",
            "if(raw==true) && if [ -s ${tmpResult} ]; then cat ${tmpResult} | jq 'map(. as $$row | ({\"id\": $$row.id} + ($$row.data | fromjson)) + {\"__metadata\": (($$row.metadata | fromjson) + {\"createdAt\": $$row.created_at, \"updatedAt\": $$row.updated_at})})'; else echo '[]'; fi || true",
            "if(raw!=true) && if [ -s ${tmpResult} ]; then cat ${tmpResult} | jq 'map(. as $$row | ({\"id\": $$row.id} + ($$row.data | fromjson)))'; else echo '[]'; fi || true",
            "rm -f ${tmpWhere} ${tmpResult}"
          ],
          "help": {
            "text": "Find in the aux4 repository using SQL expressions",
            "variables": [
              {
                "name": "db",
                "text": "The database to find in",
                "default": ".local.db"
              },
              {
                "name": "repository",
                "text": "The name of the repository to find in",
                "arg": true
              },
              {
                "name": "expr",
                "text": "SQL expression for filtering (e.g., 'age > 30 and name like \"%John%\"')"
              },
              {
                "name": "raw",
                "text": "Include metadata in the output",
                "default": "false"
              }
            ]
          }
        },
        {
          "name": "delete",
          "execute": [
            "aux4 repository init --db ${db} --repository ${repository}",
            "set:ids_json=value(id*)",
            "echo ${ids_json} | sed 's/\\[//' | sed 's/\\]//' | sed \"s/\\\"/'/g\"",
            "sqlite3 ${db} \"DELETE FROM ${repository} WHERE id IN ($response)\""
          ],
          "help": {
            "text": "Delete from the aux4 repository",
            "variables": [
              {
                "name": "db",
                "text": "The database to delete from",
                "default": ".local.db"
              },
              {
                "name": "repository",
                "text": "The name of the repository to delete from",
                "arg": true
              },
              {
                "name": "id",
                "text": "The id to delete from the repository",
                "multiple": true
              }
            ]
          }
        },
        {
          "name": "truncate",
          "execute": [
            "confirm:Are you sure you want to truncate the repository '${repository}'? This will delete all records.",
            "aux4 repository init --db ${db} --repository ${repository}",
            "sqlite3 ${db} \"DELETE FROM ${repository}\""
          ],
          "help": {
            "text": "Truncate the aux4 repository (delete all records)",
            "variables": [
              {
                "name": "db",
                "text": "The database to truncate",
                "default": ".local.db"
              },
              {
                "name": "repository",
                "text": "The name of the repository to truncate",
                "arg": true
              }
            ]
          }
        }
      ]
    }
  ]
}
